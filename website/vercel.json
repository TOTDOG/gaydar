{
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/_botid/:path*",
      "destination": "https://botid.vercel-infra.com/:path*"
    },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path((?!@)(?!.*\\.).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "includeFiles": "{data,lib}/**"
    }
  }
}