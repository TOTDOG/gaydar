datasource db {
  provider = "cockroachdb"
}

model GlobalCounter {
  metricName  String   @id
  metricValue BigInt   @default(0)
  updatedAt   DateTime @updatedAt

}

generator client {
  provider = "prisma-client-js"
}

model Comparison {
  id      String      @id @default(uuid()) @db.Uuid
  setParameters0 Json
  setParameters1 Json
  relate  Float
}

model Rank {
  id     String      @id @default(uuid()) @db.Uuid
  setParameters Json
  rank   Float
}

model Parameter {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  dateCreated DateTime @default(now())
  type  String
  active Boolean
  classes String[]
  min Int?
  max Int?
  samplePoints Json
  description String
  contextualizer String
  baselineVector Float[]
  decimals Int?
  votes Int
}