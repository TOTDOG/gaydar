{
  "name": "user-input-collector",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "prisma generate && vue-tsc -b && vite build",
    "preview": "vite preview",
    "db:push": "node --env-file=.env.local ./node_modules/prisma/build/index.js db push",
    "db:migrate": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate dev",
    "db:studio": "node --env-file=.env.local ./node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/themes": "^4.5.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "arktype": "^2.2.0",
    "botid": "^1.5.11",
    "dotenv": "^17.4.2",
    "mathjs": "^15.2.0",
    "pg": "^8.20.0",
    "primevue": "^4.5.5",
    "prisma": "^7.8.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vercel/node": "^5.8.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
